# secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
*credentials*
!*credentials.example

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/

# tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Backups the admin panel takes before it overwrites configs/sources.yaml. They
# are an undo button on one machine, not history — git already is the history.
configs/backups/

# local data — the lake lives on the NAS, never in git
data/
*.duckdb
*.sqlite
*.sqlite3
*.db
*.parquet

# notebooks
.ipynb_checkpoints/

# serving replica — derived data, rebuilt from processed/
serving/
*.building

# os
.DS_Store
