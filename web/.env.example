# Where the lake API lives. This app is the only thing that talks to it — the
# browser reaches it through this app's /api/* proxy, never directly, so the API
# can keep binding to localhost with no authentication of its own.
#
# Leave it unset in development: it defaults to http://127.0.0.1:8000, which is
# where `make serve` puts the API.
LAKE_API_URL=http://127.0.0.1:8000
