# Copy to /etc/lake/lake.env on the NUC (root:lake, chmod 0640).
# Loaded by systemd EnvironmentFile= — never appears in the process table.
# For local dev: cp .env.example .env

LAKE_ENV=development

# --- storage -----------------------------------------------------------------
# NAS mount root. Must contain a `.lake_mounted` sentinel file that exists ONLY
# on the NAS — this is how we detect an unmounted NAS before writing.
LAKE_NAS_ROOT=/mnt/nas/lake
# Staging lives on NUC-local SSD. Fast fsync, and a failed run can't pollute the NAS.
LAKE_STAGING_ROOT=/var/lib/lake/staging

# --- metadata database -------------------------------------------------------
# Production: unix socket + peer auth. No password exists to leak.
#   LAKE_DB_DSN=postgresql+psycopg://lake@/lake_meta?host=/var/run/postgresql
# Local dev over TCP:
LAKE_DB_DSN=postgresql+psycopg://lake:lake@localhost:5432/lake_meta

# --- logging -----------------------------------------------------------------
LAKE_LOG_DIR=/var/log/lake
LAKE_LOG_LEVEL=INFO
# json in prod (grep-able, Loki-ingestible); console in dev (human-readable)
LAKE_LOG_JSON=true

# --- alerting ----------------------------------------------------------------
# ntfy.sh topic. Use a long random topic name — it IS the authentication.
LAKE_ALERT_NTFY_URL=https://ntfy.sh/lake-alerts-CHANGE-ME-8f3a9c2b
LAKE_ALERT_ENABLED=true

# --- the public API ----------------------------------------------------------
# Where this API answers from, as the outside world reaches it. Dataset pages print
# copy-paste snippets (curl, Python, JavaScript, R) that POST to it, so this has to be
# the URL a reader can actually reach — not the loopback address the frontend uses to
# talk to us. Behind a reverse proxy the two are different, and a snippet that says
# `127.0.0.1` is a snippet that works on exactly one machine.
LAKE_API_PUBLIC_URL=http://localhost:8000

# --- admin panel -------------------------------------------------------------
# The panel is at /admin. Create the first account from a shell — there is no web
# sign-up, because a panel that can create its own first admin is a panel a
# stranger can claim:
#
#     lake admin create-user you@example.org
#
# Login attempts per minute, per IP. The one endpoint an attacker can call in a
# loop for free, so keep it tight: generous for a human, useless for a dictionary.
LAKE_API_RATE_LOGIN_PER_MIN=10

# --- per-source secrets ------------------------------------------------------
# Referenced from configs/sources.yaml as ${env:WORLDBANK_API_KEY}
# WORLDBANK_API_KEY=
