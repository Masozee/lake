# Only if the NAS speaks SMB and not NFS. Prefer NFS.
#
# Install as /etc/lake/smb-credentials, owned root:root, chmod 0600.
# Credentials must NEVER appear in the .mount unit or in /etc/fstab — both are
# world-readable, and `ps` / `mount` will happily print them.
#
#   sudo install -o root -g root -m 0600 smb-credentials.example /etc/lake/smb-credentials
#
# Then in mnt-nas.mount, replace the [Mount] section with:
#
#   What=//192.168.1.50/lake
#   Type=cifs
#   Options=credentials=/etc/lake/smb-credentials,uid=lake,gid=lake,file_mode=0640,dir_mode=0750,vers=3.1.1,seal,_netdev
#
# `seal` forces SMB3 encryption on the wire. `vers=3.1.1` refuses to negotiate
# down to SMB1, which is broken beyond repair.

username=lake_svc
password=CHANGE_ME
domain=WORKGROUP
